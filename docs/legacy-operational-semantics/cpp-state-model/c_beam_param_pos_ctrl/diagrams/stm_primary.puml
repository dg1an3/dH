@startuml stm_primary
title <<stm>> CBeamParamPosCtrl Primary State Machine

skinparam state {
    BackgroundColor<<browse>> #e3f2fd
    BorderColor<<browse>>     #1565c0
    FontColor<<browse>>       #0d47a1
}
skinparam shadowing false
top to bottom direction

state "pre_init" as PreInit <<browse>>
state "ready" as Ready <<browse>>
state "bound" as Bound <<browse>>

PreInit -down-> Ready : on_init_dialog
Ready -down-> Bound : set_beam(B) [B != none]
Bound -up-> Ready : set_beam(none)
Bound --> Bound : set_beam(B') [B' != none]
Bound --> Bound : on_apply_changes\non_apply_spin_changes(_)\ndo_data_exchange(true)
Ready --> Ready : do_data_exchange(false)
Bound --> Bound : do_data_exchange(false)

note right of Bound
    Each on_apply_changes triggers
    SetGantryAngle / SetCouchAngle /
    SetTableOffset on the bound CBeam
    -- all three fire GetChangeEvent
    (per c_beam_record:fires_change_event)
end note

@enduml
