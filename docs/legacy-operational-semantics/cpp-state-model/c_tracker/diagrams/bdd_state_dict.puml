@startuml bdd_state_dict
title <<bdd>> CTracker state{} dict schema
skinparam class {
    BackgroundColor<<root>> #ffe0b2
    BorderColor<<root>> #e65100
    BackgroundColor<<enumeration>> #fff9c4
    BorderColor<<enumeration>> #f9a825
}
hide circle
hide empty methods
skinparam classAttributeIconSize 0
skinparam shadowing false
left to right direction

class state <<root>> {
    win : TrackerMode
    pview : CSceneView* | none
}
class TrackerMode <<enumeration>> {
    pre_construct
    active
    destroyed
}
state "1" -- "1" TrackerMode : win
note bottom of state
    Template-method base.
    All five mouse handlers
    have empty bodies.
end note
@enduml
